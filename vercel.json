{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "routes": [
    { "src": "/",              "dest": "/dashboard/index.html" },
    { "src": "/terminal",      "dest": "/dashboard/terminal.html" },
    { "src": "/terminal.html", "dest": "/dashboard/terminal.html" },
    { "src": "/(.*)",          "dest": "/$1" }
  ]
}
