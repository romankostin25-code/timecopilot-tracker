PRODUCT_NAME=Trading Co-Pilot

# Asset universe — generated from engine/universe.py
# Run: python -c "from engine.universe import ALL_TICKERS; print(','.join(ALL_TICKERS))"
ASSET_TICKERS=SPY,QQQ,IWM,XLE,XLF,XLK,GLD,SLV,TLT,IEF,HYG,LQD,BIL,^TNX,GC=F,SI=F,CL=F,NG=F,HG=F,ZW=F,ZC=F,^VIX,UVXY,DX-Y.NYB,^IRX,BTC-USD,ETH-USD,SOL-USD,EEM,EFA,FXI

# Forecast settings
FORECAST_HORIZONS=5,30,90
FORECAST_FREQUENCY=B

# API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here
FRED_API_KEY=your_fred_key_here

# Dashboard auth
DASHBOARD_PASSWORD=your_password_here

# Alerts
ALERT_EMAIL=your_email_here
ALERT_WEBHOOK_URL=your_webhook_url_here
ALERT_MIN_CONVICTION=HIGH
ALERT_ACCURACY_THRESHOLD=0.55

# Polymarket
POLYMARKET_FETCH=true
POLYMARKET_MIN_VOLUME=25000
POLYMARKET_SPIKE_THRESHOLD=0.10

# Vercel
VERCEL_CRON_SECRET=your_secret_here

# Accuracy thresholds
CALIBRATION_TARGET=0.80
CALIBRATION_WARN=0.60
DIRECTIONAL_TARGET=0.55
DIRECTIONAL_WARN=0.50
